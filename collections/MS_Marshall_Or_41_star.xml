               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc>
                        <support>paper</support>
                        <extent>ff. 15<dimensions type="leaf" unit="mm">
                              <height>270</height>
                              <width>170</width>
                           </dimensions>
