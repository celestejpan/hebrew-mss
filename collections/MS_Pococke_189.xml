                    <msContents>
                        <summary>Inkishāf al-asrar watuhūr al-anwār by Joseph ben Judah ben Jacob
                            ibn Aknin</summary>
                        <msItem n="1" xml:id="MS_Poc_189_a">
                            <locus>ff. 1v-129v</locus>
                            <author ref="http://viaf.org/viaf/305410403">
                                <persName key="person_58755209"> Aknin, Joseph
                                    ben Judah ben Jacob Ibn, approximately
                                    1150-1220</persName>
                                <persName xml:lang="he"> אבן עקנין, יוסף בן
                                    יהודה</persName>
                            </author>
                            <title>Inkishāf al-asrar watuhūr al-anwār </title>
                            <title xml:lang="he">אנכשאף
                                    אלאסראר וטהור אלאנואר </title>
                            <note>Commentary on the Song of songs in Judeo-Arabic. </note>
                            <note>According to the colophon the scribe wrote it for himself.</note>
                            <colophon>Colophon in Judeo-Arabic on fol. 129v: <foreign xml:lang="he">"אני משה כהן בר’ חייא הכהן ... כתבתי ... יום אלתלאתה כאמס אלול
                                    סנה ה’ אלאלן ומאה וכמסא ותסעין וקת אן ג’א הון אמס כבר אן סלטאננא
                                    כלץ מן ידי אל ג’נוין"</foreign>
                            </colophon>
                            <textLang mainLang="jrb">Judeo-Arabic</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="chart">
