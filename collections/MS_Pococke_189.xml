                                </support>
                                <extent>ff. 132 </extent>
                                <foliation>Foliation in Arabic numerals.</foliation>
                            </supportDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Sephardi cursive script. </summary>
                            <handNote scope="sole" script="sephardi" rend="cursive"> </handNote>
                        </handDesc>
                        <bindingDesc>
                            <p>Brown leather binding, blind-tooled.</p>
                        </bindingDesc>
                    </physDesc>
