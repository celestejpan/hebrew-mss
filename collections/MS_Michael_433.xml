               <msContents>
                  <summary>Mahzor according the Western Ashkenazi rite for the High Holidays and
                     Sukkot</summary>
                  <msItem>
                     <title type="desc" xml:lang="he" key="work_3329">מחזור מנהג אשכנז המערבי לימים
                        נוראים ולסוכות</title>
                     <title type="desc" xml:lang="he-Latn-x-lc" key="work_3329">Maḥzor minhag
                        ashkenaz ha-maʻaravi le-yamim noraim ṿele-sukkot</title>
                     <textLang mainLang="he">Hebrew</textLang>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc>
                        <support>parchment</support>
                        <extent>ff. 243 
                           <dimensions type="leaf" unit="mm">
                           <height>324</height>
                           <width>240</width>
                           </dimensions> 
                           <note><locus>Ff. 234-243</locus>
                              were added from another manuscript and there is some overlap in
                              content.</note></extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <summary>Ashkenazic square script</summary>
                     <handNote/>
                  </handDesc>
                  <decoDesc>
                     <decoNote>On <locus>f. 117r</locus>, the enlarged initial word <hi rend="italic">kol</hi>
                        <foreign xml:lang="he">כל</foreign> from <hi rend="italic">kol nidrei</hi>
                        <foreign xml:lang="he">כל נדרי</foreign> is decorated with monochrome
                        penwork; the strokes of the letters enclose tiny quadrupeds and drgaons
                        executed in the spared-ground technique. </decoNote>
                  </decoDesc>
                  <bindingDesc>
                     <p>Light golden-brown leather over paper boards.</p>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate>[c. 1300]</origDate>
                     <origPlace>[Germany]</origPlace>
                  </origin>
                  <provenance>Owned by Zadok ben Yitsḥaḳ <foreign xml:lang="he">צדוק בן
                        יצחק</foreign> of <foreign xml:lang="he">פערקיס</foreign>, who recorded the
                     death of his mother in <date calendar="#Gregorian">1694</date> in <placeName
                        key="place_85">Sélestat</placeName> on <locus>f. 1r</locus>. On <locus>f.
                        144r</locus>, a small decorated ownership inscription by Avraham ben Shmuel
                        <foreign xml:lang="he">אברהם בן שמואל</foreign> underneath an initial
                     word.</provenance>
                  <acquisition>It belonged to the library of <persName ref="http://viaf.org/viaf/17140230" key="person_17140230">Heimann Joseph
                        Michael</persName>
                     <date calendar="#Gregorian">(1792-1846)</date>, which was purchased en bloc
                     (altogether 862 volumes) by the Bodleian Library in <date calendar="#Gregorian">1848</date> through Messrs. Asher and Co. for £1030.</acquisition>
               </history>
