               <msContents>
                  <summary>Isaac Israeli's Book on Fevers: in Judeo-Arabic</summary>
                  <msItem>
                     <title xml:lang="he" ref="njw_zty_43c">כתאב מג'מוע מן אקאויל אלאואיל פי
                        אלחמיאת</title>
                     <title xml:lang="he-Latn-x-lc">Kitāb maghmuʿ min aqāwil ālāwāyil fi
                        ālḥamiyāt</title>
                     <author key="person_34580662" ref="zzc_pmr_m3c">
                        <persName>Israeli, Isaac, approximately 832-approximately 932</persName>
                        <persName xml:lang="he">יצחק בן שלמה הישראלי</persName>
                     </author>
                     <textLang mainLang="jrb">Judeo-Arabic</textLang>
                     <note>On three folios at the beginning of the manuscript, prescriptions in
                        Hebrew and Spanish.</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc material="mixed">
                        <support>paper and parchment <p>The outer and inner bifolia of quires are
                              made of parchment, and the remaining bifolia are made of
                           paper.</p></support>
                        <extent>ff. 123 <dimensions type="leaf" unit="mm">
                              <height>248</height>
                              <width>200</width>
                           </dimensions></extent>
                        <condition><p>The final three leaves have been injured. The last of these,
                                 <locus>f. 122v</locus>, may have contained a
                           colophon.</p></condition>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <summary>Sephardic semi-cursive script</summary>
                     <handNote>The script is similar to that in <idno>MS Huntington 518</idno>
                        (Neubauer No. 1273), which was copied in Tunisia in <date
                           calendar="#Gregorian">1338</date>.</handNote>
                  </handDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate calendar="Gregorian" notBefore="1350" notAfter="1399">[late 14th
                        cent.]</origDate>
                     <origPlace>[North Africa (Tunisia?)]</origPlace>
                     <note>Watermark of the 'bull's head' type without eyes, not found in Briquet. A
                        single watermark on f. 24 is similar in shape but not in size to Briquet no.
                        3840, which is dated <date calendar="#Gregorian">1388-92</date>.</note>
                  </origin>
