                    <msContents>
                        <summary>Collection of midrashim</summary>
                        <msItem n="1" xml:id="MS_Marshall_Or_24_a">
                            <locus>ff. 1r-73v</locus>
                            <title>Pesiḳta de-Rav Kahana </title>
                            <title xml:lang="he">פסיקתא דרב
                                    כהנא</title>
                            <colophon>Colophon on fol. XXX: <foreign xml:lang="he"> "חסלת פסקתא דרב
                                    כהנא ברוך הנותן ליעף כח ולאין אונים עצמה ירבה חזק ונתחזק אני
                                    יהוצדק ב"ר אלחנן כח"י שלמתי וסימתי כל הספר ... בששי בשבת תשעה
                                    ועשרים יום לירח אדר שנת חמשים ואחת לפרט לאלף
                                ששי"</foreign>.</colophon>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                        <msItem n="2" xml:id="MS_Marshall_Or_24_b">
                            <locus>ff. 74r-154v</locus>
                            <title>Mekhilta de-Rabi Yishmaʾel </title>
                            <title xml:lang="he"> מכילתא דרבי
                                    ישמעאל</title>
                            <colophon>Colophon on fol. 154v: <foreign xml:lang="he">"סליק מכלתא כולה ואית בה מסכתא ט ... חזק ונתחזק הנני יהוצדק בר אלחנן כח"י כתבתי זה הספר אל האשל הגדול ... מורי רבינו הרב רבי אהרן ב"ר אליעזר זצ"ל"</foreign>.</colophon>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                        <msItem n="3" xml:id="MS_Marshall_Or_24_c">
                            <locus>ff. 155r-159v</locus>
                            <title>Barayta de-Melekhet ha-mishkan </title>
                            <title xml:lang="he">ברייתא
                                    דמלאכת המשכן</title>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                        <msItem n="4" xml:id="MS_Marshall_Or_24_d">
