                    <msContents>
                        <summary>Arbaʿah Ṭurim (Yoreh Deʿah) by Jacob ben Asher</summary>
                        <msItem n="1" xml:id="MS_Marsh_285_a">
                            <locus>ff. 1r-100v</locus>
                            <author ref="http://viaf.org/viaf/73882588">
