                    <msContents>
                        <summary>Mishneh Torah (Repetition of the Torah) by Maimonides</summary>
                        <msItem n="1" xml:id="MS_Arch_Selden_B_2_a">
                            <locus>ff. 1r-510v</locus>
                            <author ref="http://viaf.org/viaf/100185495/" key="person_100185495">
                                <persName>Maimonides, Moses, 1135-1204 </persName>
                                <persName xml:lang="he">משה בן מימון </persName>
                            </author>                            
                            <title xml:lang="he">משנה תורה </title>
                            <title xml:lang="he-Latn-x-lc">Mishneh Torah</title>
                            <note>With the Maimuni glosses and a few other glosses, containing mainly variations.</note>
                            <note>Sedarim Zeraʿim and Ṭohorah are missing.</note>
                            <note>At the end of the different books the respective Responsa of R. <persName ref="http://viaf.org/viaf/89860273">Meir of Rotherburg</persName>.</note>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="perg">
                                <support>parchment<watermark/>
                                </support>
                                <extent>ff. 510</extent>
                                <foliation>Foliation in Arabic numerals. </foliation>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="2"/>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Ashkenazi semi-cursive script.</summary>
                            <handNote scope="major" script="ashkenazi" rend="semi-cursive">The name Shlomoh - probably the scribe - is pointed out throughout the MS (e.g. fols. 19v, 89r, 504r).</handNote>
                        </handDesc>
                    </physDesc>
