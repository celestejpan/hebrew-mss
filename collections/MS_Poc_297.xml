                    <msContents>
                        <summary>Al Murshid al-Kafi by Tanḥum ben Joseph of Jerusalem</summary>
                        <msItem n="1" xml:id="MS_Poc_297_a">
                            <locus>ff. 1v-262r</locus>
                            <author ref="http://viaf.org/viaf/59877351">
                                <persName key="person_67929844">Tanḥum ben
                                    Joseph, of Jerusalem, -1291 </persName>
                                <persName xml:lang="he"> תנחום בן יוסף,
                                הירושלמי</persName>
                            </author>
                            <title>Al Murshid al-Kafi </title>
                            <title xml:lang="he">אלמרשד
                                    אלכאפי</title>
                            <title>
                                </title>
                            <title xml:lang="he"/>
                            <note>Dictionary on the Mishnah in Arabic.</note>
                            <colophon>Colophon by the scribe <persName>Saʿadiah ben Yaʿaḳov</persName> on fol. 261v: <foreign xml:lang="he">"בחמישי בשבא
                                    דהוא ארבעה יומין לירח תמוז שנת חמשת אלפים ומאה שמונה וארבעים
                                    ליצירה לבריאת העולם ... בעיר ג’ולס דעל מי בורות הסמוכה לעכו די על שפת הים
                                    וכתב העבד הצעיר סעדיה ב"ר יעקב נ"ע"</foreign>
                            </colophon>
                            <textLang mainLang="jrb">Judeo-Arabic</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="chart">
                                <support>paper</support>
                                <extent>ff. 263 </extent>
                                <foliation>Foliation in Arabic numerals.</foliation>
                                <condition>
                                    <p>First leaf is slightly injured.</p>
                                </condition>
                            </supportDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Oriental semi-cursive scripts. The MS was copied by at least two scribes.</summary>
                            <handNote scope="minor" script="oriental" rend="semi-cursive">The first scribe copied fols. 1v-74v, middle of line 2.</handNote>
                            <handNote scope="major" script="oriental" rend="semi-cursive">The colophon's scribe copied as from fol. 74v middle of line 2 to the end (fol. 261v) in a variety of handwriting styles and with other graphical elements which seem like four different hand.
                                
                            </handNote>
                        </handDesc>
                    </physDesc>
