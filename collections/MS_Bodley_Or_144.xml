                                <locus>fols. 132r-139v</locus>
                                <author ref="http://viaf.org/viaf/100185495/">
                                    <persName key="person_100185495">Maimonides,
                                        Moses, 1135-1204 </persName>
                                    <persName xml:lang="he">משה בן
                                        מימון </persName>
                                </author>
                                <title>Commentary on the Mishnah (Horayot) </title>
                                <title xml:lang="he">פרוש המשנה לרמב"ם (הוריות)</title>
                                <colophon>Colophon by Mosheh ben Yosef, dated Adar II 1669SE
                                    (1358CE): <foreign xml:lang="he">"סליקא מסכתא דהוריות וסליק ליה
                                        סדר נזיקין ... וכתב ... משה בר מו’ יוסף נבתוי"א לנפשו ...
                                        בחד בשבת’ דהוא ט’ יומ’ לירח אדר שני שנת א’תרמ"ט
                                        לשטרות"</foreign>
                                </colophon>
                                <textLang mainLang="he">Hebrew</textLang>
                            </msItem>
                        </msContents>
                        <physDesc>
                            <objectDesc form="codex">
                                <supportDesc material="chart">
                                    <support> paper <watermark/>
                                    </support>
                                    <extent> ff. 8 (fols. 132-139) <dimensions type="leaf" unit="mm">
                                            <height quantity="0"/>
                                            <width quantity="0"/>
                                        </dimensions>
                                    </extent>
                                    <foliation>Foliation in Arabic numerals.</foliation>
                                </supportDesc>
                                <layoutDesc>
                                    <layout columns="1"> </layout>
                                </layoutDesc>
                            </objectDesc>
                            <handDesc>
                                <summary>Oriental semi-cursive script.</summary>
                                <handNote scope="sole" script="oriental" rend="semi-cursive"> </handNote>
                            </handDesc>
                        </physDesc>
                        <history>
                            <origin>
                                <origPlace>[Orient]</origPlace>
                                <origDate when="1338">1338</origDate>
                            </origin>
                            <provenance>Fol. 139v: Latin note (probably by the same hand as on fol.
                                1r): 1649 era[m] Alexandri; erased Hebrew inscription.</provenance>
                        </history>
