                        <msContents>
                            <msItem n="1" xml:id="MS_Bodley_Or_144_1_a">
                                <locus>fol. 1r</locus>
                                <title>Shirim u-fizmonim </title>
                                <title xml:lang="he"> שירים
                                    ופזמונים </title>
                                <textLang mainLang="he">Hebrew</textLang>
                            </msItem>
                            <msItem n="2" xml:id="MS_Bodley_Or_144_1_b">
                                <locus>fols. 1v-131(iv)r</locus>
                                <author>
                                    <persName ref="http://viaf.org/viaf/34806748" key="person_34806748">Alfasi, Isaac
                                        ben Jacob, 1013-1103</persName>
                                    <persName xml:lang="he">יצחק
                                        בן יעקב אלפסי</persName>
                                </author>
                                <title>Hilkhot ha-Rif </title>
                                <title xml:lang="he">הלכות הרי"ף </title>
                                <note>Alfasi's commentary on Nezikin (Baba Batra-Avodah
                                    Zarah)</note>
                                <colophon>Colophon by Yosef bar Pinḥas ha-Rofe on fol. 131(iv)v:
                                        <foreign xml:lang="he">"נשלם על יד’ אנא יוסף בר פנחס הרופא
                                        נ"ע אילתר מחותי, ירח אדר שנת א’תרס"ב לשטרות"</foreign>.
                                    Dated Adar 1662SE (1351CE), and it refers only to fols.
                                    116v-131(iv)v. </colophon>
                                <textLang mainLang="he" otherLangs="arc">Hebrew and
                                    Aramaic</textLang>
                            </msItem>
                        </msContents>
                        <physDesc>
                            <objectDesc form="codex">
                                <supportDesc material="chart">
                                    <support> paper <watermark/>
                                    </support>
                                    <extent> ff. 134<dimensions type="leaf" unit="mm">
                                            <height quantity="0"/>
                                            <width quantity="0"/>
                                        </dimensions>
                                    </extent>
                                    <foliation>Foliation in Arabic numerals. Fol. 131 is
                                        quadruple.</foliation>
                                </supportDesc>
                                <layoutDesc>
                                    <layout columns="1"> </layout>
                                </layoutDesc>
                            </objectDesc>
                            <handDesc>
                                <summary>Oriental semi-cursive scripts.</summary>
                                <handNote scope="sole" script="oriental" rend="semi-cursive">Fol.
                                    116vr-131r are written by Yosef bar Pinḥas ha-Rofe (see
                                    colophon).</handNote>
                                <handNote scope="sole" script="oriental" rend="semi-cursive">Fol.
                                    1r-116r are written in another, contemporary hand.</handNote>
                            </handDesc>
                        </physDesc>
                        <history>
                            <origin>
                                <origPlace>[Orient]</origPlace>
                                <origDate when="1351" calendar="Gregorian">1351</origDate>
                            </origin>
                            <provenance>On fol. 1r: Latin note mentioning Edward Bernard; ownership
                                inscription: <foreign xml:lang="he">"מלך אלעבד אלפקיר מצליח בן
                                    [...?]"</foreign>
                            </provenance>
                        </history>
