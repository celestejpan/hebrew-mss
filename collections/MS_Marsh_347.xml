                        <msItem>
                            <title>Medical works</title>
                            <title xml:lang="he">תרופות</title>
                            <msItem>
                                <locus>ff. 1-5</locus>
                                <title>Medical fragment of a work by אמנ"ה, who Neubauer thought might be
                                    Moses of Narbonne.</title>
                            </msItem>
                            <msItem>
                                <locus>ff. 6-22</locus>
                                <title>Hebrew translation of part of Pseudo-Mesuë’s Canones universales (or
                                    De simplicibus)</title>
                                <title xml:lang="he">ספר אבן מאסויה</title>
                            </msItem>
                            <msItem>
                                <locus>ff. 23-36r</locus>
                                <title>Hebrew translation of Gerardus de Solo’s Libellus de febribus
                                    ejusdem. </title>
                                <title xml:lang="he">מבא הנערים</title>
                            </msItem>
                            <msItem>
                                <locus>ff. 36v-47</locus>
                                <title>Treatise on fevers by Salmias of Lunel.</title>
                                <title xml:lang="he">מבא הרפואה</title>
                            </msItem>
                            <msItem>
                                <locus>f. 48r</locus>
                                <note>blank</note>
                            </msItem>
                            <msItem>
                                <locus>ff. 48v-77r</locus>
                                <author key="person_50893463">Isaac ben Jacob Lattes</author>
                                <title>Treatise [on fevers]</title>
                                <title xml:lang="he">מאמר</title>
                            </msItem>
                            <msItem>
                                <locus>ff. 77v-150b</locus>
                                <title>Hebrew translation of Yūḥannā Ibn Māsawayh or Pseudo-Mesuë’s
                                    Antidotarium or Grabadin.</title>
                                <title xml:lang="he">אקרבדין</title>
                                <note>Marginal notes signed אמנ"ה (ff. 85r, 122r).</note>
                                <msItem>
                                    <locus>ff.77v-81r</locus>
                                    <title>Index</title>
                                </msItem>
                            </msItem>
                            
                            <msItem>
                                <locus>ff. 151-152</locus>
                                <title>Medical notes, including the healing properties of various
                                    animals.</title>
                            </msItem>
                            <msItem>
                                <locus>ff. 153v-154v </locus>
                                <title>Index</title>
                            </msItem>
                            <msItem>
                                <locus>f. 155r</locus>
                                <title xml:lang="he">מבא ארנבט העתקת גבריאל המילייאבי עם תוספותיו
                                    ומחקריו</title>
                                <note>Title added later</note>
                            </msItem>
                            <msItem>
                                <locus>ff. 157-197</locus>
                                <note>Hebrew translation of Arnaldus de Villanova’s <title>Tabula super Vita
                                        brevis</title>. With a commentary by the translator Gabriel of Milhaud
                                    (גבריאל המילייאבי), later identified by A. Neubauer and E. Renan as
                                    Hezekiah Milhaud [also known as Bonenfant de Milhaud], on the basis of a
                                    comparison with MS. Moscow Guenzburg 316.</note>
                            </msItem>
                            <msItem>
                                <locus>ff. 198-199r</locus>
                                <note>A fragment on leprosy.</note>
                            </msItem>
                            <msItem>
                                <locus>ff. 199v-200</locus>
                                <note>A fragment on medical astrology.</note>
                            </msItem>
                            <msItem>
                                <locus>ff. 201r-202v</locus>
                                <note>Fragment.</note>
                            </msItem>
                            <msItem>
                                <locus>f. 202-203r (ff. 203v-204 blank)</locus>
                                <note>Fragment</note>
                                <title xml:lang="he">מרקחת מהר"ן</title>
                            </msItem>
                            <msItem>
                                <title>205r</title>
                                <title>Fragment. (f. 205v blank)</title>
                            </msItem>
                            <msItem>
                                <locus>ff. 206-261r</locus>
                                <note>Medical treatise in the form of questions and answers by Jean de
                                    Saint-Amand. Translator not mentioned. (f. 221 blank; ff. 206-220
                                    repeated on ff. 222 onwards)</note>
                            </msItem>
                            <msItem>
                                <locus>f. 262v</locus>
                                <note>Fragment</note>
                            </msItem>
                        </msItem>
