                    <msContents>
                        <summary>Shesh kenafayim by Immanuel ben Jacob Bonfils</summary>
                        <msItem n="1" xml:id="MS_Bodley_Or_204_a">
                            <locus>ff. 1r-25v</locus>
                            <author ref="http://viaf.org/viaf/260466183">
                                <persName>Bonfils, Immanuel
                                    ben Jacob, active 14th century</persName>
                                <persName xml:lang="he">עמנואל בן יעקב</persName>
                            </author>
                            <title>Shesh kenafayim </title>
                            <title xml:lang="he"> שש
                                כנפים</title>
                            <note>Beginning and end are wanting.</note>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="chart">
                                <support>paper<watermark/>
                                </support>
                                <extent>ff. 25</extent>
                                <foliation>Foliation in Arabic numerals.</foliation>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="1"/>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Sephardi semi-cursive script.</summary>
                            <handNote scope="major" script="sephardi" rend="semi-cursive"/>
                        </handDesc>
                        <bindingDesc>
                            <p>Half bound, marble paper.</p>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>[Turkey?]</origPlace>
                            <origDate notBefore="1550" notAfter="1600" calendar="Gregorian">[mid-late 16th
                                century]</origDate>
                        </origin>
                        <provenance>
                            <p>Hardly legible ownership inscriptions: ?<foreign xml:lang="he">אברהם כהן"
                                    "שומלא</foreign> (fol. 5r); ?<foreign xml:lang="he">"מקנת כספה[!]
                                    בימה חרפה בימה צלטן סלאמן אני הצעיר מנצור אליא
                                    יצ"ו"</foreign> (fol. 5v); ?<foreign xml:lang="he">"הצעיר אלעזר אליא יצ"ו"</foreign> (fol. 25v).</p>
                            <p>Belonged to the manuscript collection of Dr Edward Bernard
                                (1638-1696/7, the Savilian Professor of Astronomy in St John's
                                College, Oxford; ownership inscription on fol. 1r: Ed<hi rend="sup">o</hi> Bernard</p>
                        </provenance>
                        <acquisition>Bought from Dr <persName>Edward Bernard</persName>'s widow in
                            1698 (see, <hi rend="italic">Summary Catalogue</hi>, vol. III, p.
                            1)</acquisition>
                    </history>
