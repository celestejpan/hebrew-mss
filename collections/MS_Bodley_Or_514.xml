                    <msContents>
                        <summary>Kitāb al-Kāfī by Muḥammad  ibn Zakarīyā Rāzī</summary>
                        <msItem n="1" xml:id="MS_Bodl_Or_514_a">
                            <locus>ff. 1r-114v</locus>
                            <author ref="http://viaf.org/viaf/95154093">
                                <persName key="person_95154093">Rāzī, Abū Bakr
                                    Muḥammad ibn Zakarīyā, 865?-925? </persName>
                                <persName xml:lang="he"> ראזי, מחמד בן זכריה</persName>
                            </author>
                            <title>Kitāb al-Kāfī</title>
                            <title xml:lang="he"> כתאב
                                אלכאפי</title>
                            <colophon>Colophon by <persName>Yosef ben Saadia ha-Rofe for his brother
                                    Avraham, finished 5175AM (1415CE)</persName>: <foreign xml:lang="he">"... וכאן תמאמה יום אל ה’ ... כ"ח ... טבת שנת
                                    ה’א’ג’י’ד’ ל’ך’ א’ד’ם’ מ’ה’ ט’ו’ב’ והו ל...אכי ר’ אברהם הה"ה י"ל
                                    כתיבת ימין יוסף הצעיר בכ"ר סעדייא הרופא"</foreign> (fol.
                                114v)</colophon>
                            <textLang mainLang="jrb">Judeo-Arabic</textLang>
                        </msItem>
