                    <msContents>
                        <summary>Hebrew Bible ('Serugiel Bible')</summary>
                        <msItem n="1" xml:id="MS_Arch_Selden_A_47_a">
                            <locus>ff. 1r-394v</locus>
                            <title xml:lang="he">תנ"ך</title>
                            <title xml:lang="he-Latn-x-lc">Tanakh</title>
                            <note>With Rashi's commentary.</note>
                            <colophon>Colophon on fol. 394v: <foreign xml:lang="he">"אני שמואל בר’
                                    יעקב סרוגיאל ... כתבתי דניאל ועזרא אלו ... ל[...מחוק] ונשלם בעיר
                                    שוריא בשנת [תתרס"ד]"</foreign>.</colophon>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="perg">
                                <support>parchment<watermark/>
                                </support>
                                <extent>ff. 400 (iii+395+2)</extent>
                                <foliation>Foliation in Arabic numerals. </foliation>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="2">Main text in two columns. Pricking is noticable
                                    in the inner margins.</layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Sephardi square script; written by several scribes.</summary>
                            <handNote scope="major" script="sephardi" rend="square">The colophon's
                                scribe, Samuel ben Jacob copied fols. 374r-374v,
                                376v-394v.</handNote>
                        </handDesc>
                        <additions>
                            <p>Fols. 397-398 is a biblical fragment from another manuscript.</p>
                        </additions>
                        <bindingDesc>
                            <p>Mottled calf binding with blind-tooled lace border.</p>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>Soria (Spain)</origPlace>
                            <origDate notBefore="1303" notAfter="1304" calendar="Gregorian">1303/1304</origDate>
                        </origin>
                        <provenance>Censorship note on fol. 395r (flyleaf): "La presente Bibia
                            manoscritta é stata veduta da me diligentem e trovato translato
                            fidelissimus scritta con ogni accuratezza cose de punti come di accenti
                            l'anno 5064 alla creatione del mondo con il massored piccolo e
                            l'esposicion di Rabbi Salomone sopra il questa del'antichità è realtà è
                            venissima è bona. Io Leon Mdena, Rabi Eb. in Venetia, il di 8 octobre
                            1628 de Christ. Se è 5388 alla creatione del mondo secondo il computo de
                            gli Eb."</provenance>
                        <acquisition>The MS belonged to the collection of John Selden (1584-1654),
                            lawyer and historical and linguistic scholar and it was acquired by the
                            Library in 1659.</acquisition>
                    </history>
