                    <msContents>
                        <summary>Kitab al-bayan by Tanḥum ben Joseph of Jerusalem</summary>
                        <msItem n="1" xml:id="MS_Poc_344_a">
                            <locus>ff. 1r-276r</locus>
                            <author ref="http://viaf.org/viaf/59877351">
                                <persName key="person_67929844">Tanḥum ben
                                    Joseph, of Jerusalem, -1291 </persName>
                                <persName xml:lang="he"> תנחום בן יוסף,
                                הירושלמי</persName>
                            </author>
                            <title>Kitab al-bayan </title>
                            <title xml:lang="he"> כתאב אלביאן
                                    תאליף</title>
                            <note>Second volume of the commentary; first volume: MS. Pococke 314 (Neubauer 318).</note>
                            <note>Solomon ben Eleazar ha-Rofe ben Ovadiyah ha-Rofe by himself.</note>
                            <colophon>Colophons at the end of Jeremiah (dated 15 Nisan 1693SE [1382CE]fol. 55r), Ezekiel (fol. 123v)and the Twelve minor prophets (dated 13 Nisan 1696SE [=1385CE]fol. 274r).</colophon>
                            <textLang mainLang="jrb">Judeo-Arabic</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="chart">
