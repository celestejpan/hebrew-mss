               <msContents>
                  <summary>A catalogue of books in alphabetical order</summary>
                  <msItem>
                     <title xml:lang="he" key="work_3331">רשימת ספרים</title>
                     <title xml:lang="he-Latn-x-lc" key="work_3331">Reshimat sefarim</title>
                     <author key="person_386">
                        <persName>Jacob ben Isaac ibn Baḳudah Roman</persName>
                        <persName xml:lang="he">יעקב בן יצחק אבן בקודה רומן</persName>
                     </author>
                     <note><p>The list includes both printed books and manuscripts.</p>
                        <p>Titles beginning with the letters <hi rend="italic">resh</hi> and <hi
                              rend="italic">shin</hi> are copied on the verso of the folio
                           containing titles beginning with the letter <hi rend="italic">bet</hi>,
                           and titles beginning with the letter <hi rend="italic">tav</hi> are
                           copied on the verso of the folio containing titles beginning with the
                           letters <hi rend="italic">gimel</hi> and <hi rend="italic">dalet</hi>,
                           presumably because these two sides were initially left blank; the folios
                           are otherwise in alphabetical order.</p>
                        <p>Authors of the seventeenth century are quoted.</p></note>
                     <textLang mainLang="he">Hebrew</textLang>
                  </msItem>
               </msContents>
