                     <origDate calendar="Gregorian" when="1452">1452</origDate></origin>
                  <provenance/>
                  <acquisition>It belonged to the oriental collection of <persName
                        ref="http://viaf.org/viaf/34684157" key="person_131">Robert
                        Huntington</persName>
                     <date calendar="#Gregorian">(1637-1701)</date>, and was bought in <date
                        calendar="#Gregorian">1693</date> together with 645 other MSS for £752
                     10s.</acquisition>
               </history>
