               <msContents>
                  <summary>Tanḥum ben Joseph's dictionary <hi rend="italic">The Sufficient
                        Guide</hi>: in Judeo-Arabic</summary>
                  <msItem>
                     <title xml:lang="he" key="work_3346" ref="elz_zty_43c">כתאב אלכאפי נהו כתאב
                        אלמרשד</title>
                     <title xml:lang="he-Latn-x-lc" key="work_3346" ref="elz_zty_43c">Kitāb al-kāfī
                        nahw kitāb al-murshid</title>
                     <author key="person_67929844" ref="vm2_pmr_m3c">
                        <persName>Tanḥum ben Joseph, of Jerusalem, -1291</persName>
                        <persName xml:lang="he">תנחום בן יוסף הירושלמי</persName></author>
                     <textLang mainLang="jrb">Judeo-Arabic</textLang>
                     <note>Contains the text from the letter <foreign xml:lang="he">פ</foreign>to
                        the end.</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc>
                        <support>paper</support>
                        <extent n="130">ff. 130 <dimensions type="leaf" unit="mm">
                              <height>268</height>
                              <width>180</width>
                           </dimensions></extent>
                        <condition>The older portion of the manuscript (<locus>ff. 4-78</locus>) has
                           sustained significant worm damage, and the individual holes have been
                           repaired using small pieces of cut-up paper manuscripts in both Hebrew
                           and Arabic scripts.</condition>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <summary>Oriental semi-cursive scripts</summary>
                     <handNote><locus>Ff. 4-78</locus> of this manuscript were once part of a
                        damaged, fourteenth-century original, where the lost beginning (<locus>ff.
                           2-3</locus>) and end (<locus>ff. 79-129</locus>) were subsequently
                        recopied by a slightly later hand on different paper. It was this second
                        scribe who wrote the colophon on <locus>f. 129v</locus>, which is dated to
                           <date calendar="Gregorian">1452</date>.</handNote>
                  </handDesc>
                  <bindingDesc>
                     <p>Marbled paper over thin paper boards, quarter-bound in reddish-brown
                        fine-grained leather with simple blind-tooled decorations on the spine. The
                        name of the author (‘R. TANCHUM’) and the current shelfmark have been
                        gold-tooled on the spine.</p>
                     <condition>
                        <p>Some loose quires.</p>
                     </condition>
                  </bindingDesc>
               </physDesc>
