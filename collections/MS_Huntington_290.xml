               <msContents>
                  <summary>David Ḳimḥi's <hi rend="italic">Sefer ha-Shorashim</hi> (The Book of
                     Roots)</summary>
                  <msItem>
                     <title xml:lang="he-Latn-x-lc" key="work_69">Sefer ha-Shorashim</title>
                     <title xml:lang="he" key="work_69" ref="xrv_zty_43c">ספר השרשים</title>
                     <author key="person_100213323" ref="drc_pmr_m3c">
                        <persName>Ḳimḥi, David, approximately 1160-approximately 1235</persName>
                        <persName xml:lang="he"/>דוד בן יוסף קמחי</author>
                     <textLang mainLang="he">Hebrew</textLang>
                     <note>Between <locus>f. 6v</locus> and <locus>f. 7r</locus>, a large portion of
                        the text from the middle of the entry for <foreign xml:lang="he"
                           >אדם</foreign> to the middle of the entry for <foreign xml:lang="he"
                           >הלך</foreign> is missing.</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc>
                        <support>paper</support>
                        <extent n="366">ff. 366 <dimensions type="leaf" unit="mm">
                              <height>272</height>
                              <width>185</width>
                           </dimensions></extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <summary>Oriental semi-cursive script</summary>
                     <handNote>At the end of the manuscript (<locus>f. 366v</locus>), a colophon has
                        been erased; the scribe copied for himself.</handNote>
                  </handDesc>
                  <decoDesc>
                     <p>The individual roots have been written in larger, stylised letters in red
                        ink and outlined in black ink.</p>
                  </decoDesc>
                  <bindingDesc>
                     <p>Envelope-style binding, with cream-coloured cloth over thin paper boards,
                        quarter-bound in brown and dark reddish-brown fine-grained leather with
                        blind-tooled decoration. The flap has been lined on the inside with marbled
                        paper. The author’s name (‘KIMCHI’) and the current shelfmark have been
                        gold-tooled on the spine. F. 1 of the manuscript has been used as a
                        pastedown.</p>
                     <condition>
                        <p>Some detached and loose quires.</p>
                     </condition>
                  </bindingDesc>
               </physDesc>
