                    <msContents>
                        <summary>Commentary on the Mishnah (Seder Ḳodashim) by Maimonides</summary>
                        <msItem n="1" xml:id="MS_Poc_237_a">
                            <locus>ff. 2v-225v</locus>
                            <author>
                                <persName ref="http://viaf.org/viaf/100185495" key="person_100185495">Maimonides,
                                    Moses, 1135-1204 </persName>
                                <persName xml:lang="he"> משה בן
                                    מימון</persName>
                            </author>
                            <title>Commentary on the Mishnah (Seder Ḳodashim) </title>
                            <title xml:lang="he"> פרוש המשנה לרמב"ם בערבית (סדר
                                קדשים)</title>
                            <note>See also <ref target="                                 /p/m/zstmpdbcv955v84wmqtnyad37g">MS. Pococke 238</ref>, <ref target="/p/m/de17e34d654wseqgjhbnnjmfrm">MS. Pococke 236</ref>, <ref target="                                 /p/m/mfqtsxypzh4g778q21beaa5sm8">MS. Pococke 235</ref>, MS. Pococke 97, and <ref target="/p/m/j2my51k61n1hh4fcpmnrny57m8">MS. Pococke
                                        233</ref>.</note>
                            <colophon>Colophon on fols. 224r-225v: <foreign xml:lang="he">"נגמר סדר
                                    קדשים בעזרת שדי בירח כסליו שנת א’תקל"ה לשטרות וברוך העוזר וישבו אחד עשר מסכתות וזה הוא פירושין ... וכתב שלמה הלוי ב"ר
                                    ... שמואל הדיין המשכיל"</foreign>
                            </colophon>
                            <textLang mainLang="jrb">Judeo-Arabic </textLang>
                        </msItem>
