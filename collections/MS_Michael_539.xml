               <msContents>
                  <summary>The Book of Education</summary>
                  <msItem>
                     <title xml:lang="he" key="work_3343">ספר החינוך</title>
                     <title xml:lang="he-Latn-x-lc" key="work_3343">Sefer ha-Ḥinukh</title>
                     <author key="person_86224841">
                        <persName>Aaron, ha-Levi, of Barcelona, active 13th century-14th
                           century</persName>
                        <persName xml:lang="he">אהרן הלוי, מברצלונה</persName>
                     </author>
                     <note>Attributed to Aaron ha-Levi of Barcelona.</note>
                     <textLang mainLang="he">Hebrew</textLang>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc>
                        <support>parchment</support>
                        <extent>ff. 276 </extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <summary>Italian semi-cursive script</summary>
                     <handNote>Copied by <persName>Solomon ben Isaac <lang xml:lang="he">שלמה בן
                              יצחק</lang></persName> for <persName> Moses of Sirmiano (?) <lang
                              xml:lang="he">משה דסירמיאנו</lang></persName>, as stated in the
                        scribal colophon on <locus>f. 275v</locus>.</handNote>
                  </handDesc>
                  <bindingDesc>
                     <p>Golden-brown fine-grained leather over paper boards; the current shelfmark
                        has been gold-tooled and painted (in black and white) on the spine.</p>
                     <p>A red leather spine label bearing the gold-tooled title 'ספר החינוך',
                        presumably from the manuscript's previous binding, has been glued to the
                        front pastedown.</p>
                  </bindingDesc>
                  <accMat>On <locus>f. 276v</locus>, which belongs to the same quire as the previous
                     folios and had originally been left blank, a list of times and dates for the
                     four <hi rend="italic">teḳufot</hi> of 26 successive years has been copied in
                     an early-sixteenth-century Italian semi-cursive hand; some of the text
                     (including the years) has been lost due to the trimming of the side margin.
                  </accMat>
               </physDesc>

               <history>
                  <origin>
                     <origDate>[mid-14th cent.]</origDate>
                     <origPlace>[Italy]</origPlace>
                  </origin>
                  <provenance>
                     <p>On <locus>ff. 1r and 276v</locus>, ownership inscriptions by Abraham ben
                        Ephraim from Costilo (Castile?) <lang xml:lang="he">אברהם בכמ"ר אפרים
                           מקויסטילו/מקווסטילו</lang>, his son Aaron ben Abraham <lang xml:lang="he"
                           >אהרן בכמ"ר אברהם מקויסטילו</lang>, and Moses ben Abraham Norzi (Norsa)
                           <lang xml:lang="he">משה בכמה"ר אברהם נורצי </lang>.</p>
                     <p>Censorship certificates by <persName key="person_315200936">Giovanni
                           Domenico Carretto</persName> in <date calendar="#Gregorian">1617</date>
                           (<locus>f. 275r</locus>), and by <persName key="person_79251093">Domenico
                           Hierosolimitano</persName> (no date; <locus>f. 275v</locus>).
                     </p></provenance>
                  <acquisition>It belonged to the library of <persName
                        ref="http://viaf.org/viaf/17140230" key="person_17140230">Heimann Joseph
                        Michael</persName>
                     <date calendar="#Gregorian">(1792-1846)</date>, which was purchased <hi
                        rend="italic">en bloc</hi> (altogether 862 volumes) by the Bodleian Library
                     in <date calendar="#Gregorian">1848</date> through Messrs. Asher and Co. for
                     £1030.</acquisition>

               </history>
