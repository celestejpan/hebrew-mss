                    <msContents>
                        <summary>Pentateuch (Numbers-Deuteronomy) and Hafṭarot</summary>
                        <msItem n="1" xml:id="MS_Marshall_Or_51_a">
                            <locus>ff. 1r-243v</locus>
                            <title>Pentateuch (Numbers-Deuteronomy) and Hafṭarot</title>
                            <title xml:lang="he"> תורה (במדבר-דברים) והפטרות</title>
                            <note>From Numbers 4:44, with Onḳelos after each verse, Rashi and the
                                Hafṭarot in the margins.</note>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="perg">
                                <support>parchment</support>
                                <extent>ff. 243</extent>
                                <foliation>Foliation in Arabic numerals. </foliation>
                            </supportDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Ashkenazi square and semi-cursive script. Written by Moses who
                                pointed out his name in the Rashi commentary (e.g., fols. 11r, 161v,
                                222r) and in the biblical text (e.g., fols. 102r, 242r). The Hafṭarot were copied by two different hands: fols. 1-36v by one hand and fols. 37r-243v by another.</summary>
                            <handNote scope="major" script="ashkenazi" rend="square">Square script
                                for biblical texts,</handNote>
                            <handNote scope="minor" script="ashkenazi" rend="semi-cursive">semi-cursive script for Rashi.</handNote>
                        </handDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>[France?]</origPlace>
                            <origDate notBefore="1251" notAfter="1300" calendar="Gregorian">[second half of 13th century]</origDate>
                        </origin>
                        <provenance>Ownership inscription on fol. XXX: <foreign xml:lang="he">"יששכר ב"ר מאיר הלוי"</foreign> and <foreign xml:lang="he">"משה בר שלמה"</foreign>.</provenance>
                        <acquisition>Thomas Marshall (1620/1-1685), rector of Lincoln College, Oxford, bequeathed his MSS to the University of Oxford, which received them with delay in 1689-1890. </acquisition>
                    </history>
