                    <msContents>
                        <summary>Treasure of Honour (ʾOtsar ha-kavod) by Todros Abulafia</summary>
                        <msItem n="1" xml:id="MS_Arch_Selden_A_50_a">
                            <locus>ff. 1r-208v</locus>
                            <title xml:lang="he">אוצר הכבוד</title>
                            <title xml:lang="he-Latn-x-lc">ʾOtsar ha-kavod</title>
                            <author ref="http://viaf.org/viaf/24783259" key="person_24783259">
                                <persName>Abulafia, Todros ben Joseph, ha-Levi, approximately 1220-1298</persName>
                                <persName xml:lang="he">אבולעפיה, טודרוס בן יוסף, הלוי</persName>
                            </author>                    
                            <note>Mystical commentary on the aggadic passages of the Babylonian Talmud.</note>
                            <colophon>Colophon on fol. XXX: <foreign xml:lang="he">"הצעיר חיים
                                    בכמאר שמואל אבן גאטינייו"</foreign>.</colophon>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
