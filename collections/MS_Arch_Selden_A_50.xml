                        <objectDesc form="codex">
                            <supportDesc material="chart">
                                <support>paper<watermark/>
                                </support>
                                <extent>ff. 208</extent>
                                <foliation>Foliation in Arabic numerals. </foliation>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="1"/>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Sephardi-Byzantine semi-cursive script.</summary>
                            <handNote scope="major" script="byzantine" rend="semi-cursive"/>
                        </handDesc>
                    </physDesc>
                    <history>
