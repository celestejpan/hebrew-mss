                    <msContents>
                        <summary>Hebrew Bible: Pentateuch, Hafṭarot, Five Scrolls and Job</summary>
                        <msItem n="1" xml:id="MS_Marshall_Or_1_a">
                            <locus>ff. 1r-307v</locus>
                            <title>Hebrew Bible: Pentateuch, Hafṭarot, Five Scrolls and Job </title>
                            <title xml:lang="he"> תורה, הפטרות, מגלות ואיוב</title>
                            <note>Pentateuch with Targum Onḳelos after each verse and both masorahs
                                in the margins.</note>
                            <note>At the end of Pentateuch are rules for writing a ketubah.</note>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="perg">
                                <support>parchment</support>
                                <extent>ff. 307</extent>
                                <foliation>Foliation in Arabic numerals. </foliation>
                            </supportDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Ashkenazi square script. Probably written by three scribes, one
                                of them Judah (name Yehudah in the copied text is pointed out
                                several times(e.g., fols. 34v, 270r). The name Yitsḥaḳ bar Pesaḥ,
                                which is formed by the masorah on fol. 196r, probably indicates the
                                masorete's name.</summary>
                            <handNote scope="major" script="ashkenazi" rend="square"/>
                        </handDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>[Ashkenaz]</origPlace>
                            <origDate notBefore="1276" notAfter="1300" calendar="Gregorian">[late 13th century]</origDate>
                        </origin>
                        <provenance/>
                        <acquisition>Thomas Marshall (1620/1-1685), rector of Lincoln College, Oxford, bequeathed his MSS to the University of Oxford, which received them with delay in 1689-1890. </acquisition>
                    </history>
