                    <msContents>
                        <summary>Commentary on the Sifra by Abraham ben David of Posquières</summary>
                        <msItem n="1" xml:id="MS_Bodl_Or_593_a">
                            <locus>ff. 1r-340r</locus>
                            <author ref="http://viaf.org/viaf/8687273">
                                <persName key="person_8687273">Abraham ben David,
                                    of Posquières, approximately 1125-1198 </persName>
                                <persName xml:lang="he"> אברהם בן דוד, מפוסקיר </persName>
                            </author>
                            <title>Commentary on the Sifra </title>
                            <title xml:lang="he"> פרוש
                                ספרא</title>
                            <note>On fol. 1r (flyleaf), a fragment fromYom-Tob ben Abraham Ishbili's commentary on BM 34a (see Beit-Arie, 1994). </note>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
