                    <msContents>
                        <summary>Commentary on the Prophets (Jesaiah) by David Kimhi</summary>
                        <msItem n="1" xml:id="MS_Marsh_142_a">
                            <locus>ff. 1v-130r</locus>
                            <author ref="http://viaf.org/viaf/100213323">
                                <persName key="person_100213323">Kimhi, David,
                                    approximately 1160-approximately 1235 </persName>
                                <persName xml:lang="he">קמחי, דוד בן יוסף</persName>
                            </author>
                            <title>Commentary on the Prophets (Jesaiah) </title>
                            <title xml:lang="he">פרוש
                                    נביאים לרד"ק (ישעיה)</title>
                            <colophon>Colophon on fol. 130r: <foreign xml:lang="he"> "נשלם ... ביום
                                    ששי עשרה ימים לחדש אב י"ל שנת מ’ח’ר’ ... לפרט האלף הששי בצובה,
                                    על ידי ... יוסף ברכ"ה ר’ לוי זלה"ה ברכ"ה רבי משה ... בן אלייד
                                    ... והוא לחכם ... הר’ משה נר"ו ברכה ... עובדיה נר"ו בן עבד אל
                                    מוחסן".</foreign>
                            </colophon>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                        <msItem n="2" xml:id="MS_Marsh_142_b">
                            <locus>ff. 130v-218r</locus>
                            <author ref="http://viaf.org/viaf/97166726">
                                <persName key="person_97166726">Ibn Tibbon,
                                    Shmuel, active 12th century-13th century</persName>
                                <persName xml:lang="he">אבן תבון, שמואל בן יהודה,
                                1150-1230</persName>
                            </author>
                            <title>Maʾamar yiḳaṿu ha-mayim </title>
                            <title xml:lang="he"> מאמר יקוו
                                    המים</title>
                            <note>A philosophical treatise on Gen. 1:9.</note>
                            <colophon>Colophon on fol. 218r: <foreign xml:lang="he">"והיתה השלמתו יום
                                    ששי ששה ועשרים יום לחדש אב י"ל של שנת מ’ח’ר’ ... לפרט האלף הששי
                                    ... על ידי .... יוסף ברכ"ה ר’ לוי זלה"ה ברכ"ה ר’ משה זלה"ה ...
                                    בן אלייד והוא לחכם ... הרב ר’ משה נר"ו בן עבד אל מחסן" </foreign>.</colophon>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                        <msItem n="3" xml:id="MS_Marsh_142_c">
                            <locus>f. 219r</locus>
                            <title>Fragment of a theologico-ethical work</title>
                            <incipit>
                                <foreign xml:lang="he">אפשר אדם לומ'</foreign>
                            </incipit>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
