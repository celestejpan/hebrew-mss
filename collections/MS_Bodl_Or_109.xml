                    <msContents>
                        <summary>Commentary on prayers and liturgical poems by Aharon ben Ḥayim ha-Kohen</summary>
                        <msItem n="1" xml:id="MS_Bodley_Or_109_a">
                            <locus>ff. 1r-85v</locus>
                            <editor role="compiler" key="person_6962844">
                                <persName>Aharon ben Ḥayim, ha-Kohen</persName>
                                <persName xml:lang="he"> אהרן בן חיים, הכהן </persName>
                            </editor>
                            <title xml:lang="he"> פרוש תפלות ופיוטים</title>
                            <title xml:lang="he-Latn-x-lc">Parush tefilot v-piyyuṭim</title>
                            <note>Numerous marginal notes. Commentaries on liturgical poems for Yom
                                Kipur and Sukot and on many for seliḥot.</note>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="perg">
                                <support>parchment<watermark/>
                                </support>
                                <extent>ff. 85</extent>
                                <foliation>Foliation in Arabic numerals. Fol. 27 is
                                    quadruple.</foliation>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="1"/>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Ashkenazi semi-cursive scripts.</summary>
                            <handNote scope="sole" script="ashkenazi" rend="semi-cursive"> </handNote>
                        </handDesc>
                        <bindingDesc>
                            <p>Brown leather binding.</p>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>[Ashkenaz]</origPlace>
                            <origDate notBefore="1301" notAfter="1325" calendar="Gregorian">[early 14th
                                century]</origDate>
                        </origin>
                        <provenance>
                            <p>Ownership inscriptions on fol. 37r: <foreign xml:lang="he">משה
                                בר מאיר בלאך, שמואל בר אברהם</foreign>; above these a partially
                            erased inscription, perhaps reads as <foreign xml:lang="he">נחום בר מאיר זצ"ל פה הדר...</foreign>.</p>
                            <p>Belonged to the manuscript collection of Dr Edward Bernard (1638-1696/7, the Savilian Professor of Astronomy in St John's College, Oxford).</p>
                        </provenance>
                        <acquisition>Bought from Dr <persName>Edward Bernard</persName>'s widow in 1698 (see, <hi rend="italic">Summary Catalogue</hi>, vol. III, p. 1)</acquisition>
