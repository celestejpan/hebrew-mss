                    <msContents>
                        <summary>Commentary on the Pentateuch (Genesis, Numbers) Shmuel ben Daṿid
                            ben Shlomoh </summary>
                        <msItem n="1" xml:id="MS_Marsh_626_a">
                            <locus>ff. 2v-172r</locus>
                            <author>
                                <persName>Shmuel ben Daṿid ben Shlomoh </persName>
                                <persName xml:lang="he">שמואל בן דוד בן שלמה</persName>
                            </author>
                            <title>Commentary on the Pentateuch (Genesis, Numbers) </title>
                            <title xml:lang="he"> פרוש התורה לשמואל בן דוד בן שלמה (בראשית,
                                    במדבר)</title>
                            <note>Continuation of <ref target="/p/m/r3764e46r16nq16fa25s670hdw">MS.
                                    Marsh 643</ref> which contains the commentary on Genesis.</note>
                            <note>Contains the commentary on Numbers.</note>
                            <note>Volumes on Exodus, Leviticus and Deuteronomy are missing. </note>
                            <colophon>Colophon on fol. 172r:<foreign xml:lang="he">"תם ונשלם ארבעה
                                    ספרים בעזרת היודע הנסתרים ונתחיל ספר אלה הדברים -ד שנת אתתכ"ג
                                    לשט’ פירוש ר’ שמואל הנגיד ז"ל"</foreign>.</colophon>
                            <textLang mainLang="he">Hebrew</textLang>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="codex">
                            <supportDesc material="chart">
                                <support>paper <watermark>(watermarks)</watermark>
                                </support>
                                <extent>ff. 172</extent>
                                <foliation>Foliation in Arabic numerals. Fol. 154 is
                                    blank.</foliation>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="1"/>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <summary>Oriental semi-cursive script. </summary>
                            <handNote scope="sole" script="oriental" rend="semi-cursive"/>
                        </handDesc>
                        <additions>
                            <p>Front flyleaf (fol. 1) is a fragment from the Mishneh Torah by Maimonides, Sephardi semi-cursive script.</p>
                        </additions>
                        <bindingDesc>
                            <p>Brown leather binding, blind-tooled.</p>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origPlace>[Orient]</origPlace>
                            <origDate when="1512" calendar="Gregorian">1512</origDate>
                        </origin>
                        <provenance>Ownership inscriptions on fol. 172r: one in Judeo-Arabic, and
                            one in Hebrew; the latter is erased, hardly legible. <persName key="person_198149106169068491350">Narcissus
                                Marsh</persName>' Greek motto on fol. 2r: <foreign xml:lang="gre">πανταχῇ τὴν ἀλήθειαν</foreign>.</provenance>
                        <acquisition>It was bequeathed to the Library by Narcissus Marsh
                            (1638-1713), Church of Ireland archbishop of Armagh together with the
                            rest of his Oriental MSS in 1714 (<hi rend="italic">Summary
                                Catalogue</hi>, vol. III, p. 45).</acquisition>
                    </history>
