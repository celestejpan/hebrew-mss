               <msContents>
                  <summary>Guide to the duties of the heart: in Judeo-Arabic</summary>
                  <msItem>
                     <title xml:lang="he" key="work_3332">כתאב אלהדאיה לפראיץ אלקלוב</title>
                     <title xml:lang="he-Latn-x-lc" key="work_3332">Kitab al-hidaya le-faraits
                        al-ḳalub</title>
                     <author key="person_180286221">
                        <persName>Baḥya ben Joseph ibn Paḳudah, active 11th century</persName>
                        <persName xml:lang="he">בחיי בן יוסף אבן פקודה</persName>
                     </author>
                     <textLang mainLang="he">Judeo-Arabic</textLang>
                     <note/>
                     <note>Marginal notes contain frequent omissions.</note>
                     <note>Colophon by the scribe, <persName key="person_7053">Abraham bar
                           Tahur</persName>
                        <foreign xml:lang="he">אברהם בר טהור</foreign>, on <locus>ff.
                           142r-142v</locus>.</note>
                     <note>At the end of the manuscript, two items in later hands: a note on
                        Tamerlane's conquest of Aleppo around the year 1400 (<locus>f.
                        143r</locus>), and liturgical compositions of Baḥya ben Joseph ibn Paḳuda
                        in Hebrew, including <foreign xml:lang="he">ברכי נפשי</foreign> and <foreign
                           xml:lang="he">אדני שפתי תפתח</foreign> (<locus>ff.
                        143v-155v</locus>).</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="codex">
                     <supportDesc>
                        <support>paper</support>
                        <extent>ff. 156</extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <summary>Oriental semi-cursive script</summary>
                     <handNote>The same scribe, Abraham bar Tahur, also copied MS Huntington
                        135.</handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote>Simple penwork borders and rudimentary drawings of semi-abstract
                        flowers around enlarged initial words.</decoNote>
                  </decoDesc>
                  <bindingDesc>
                     <p>Envelope-style binding with dark reddish-brown fine-grained leather over
                        paper boards; the leather originally covering the spine and the flap has
                        been replaced by smooth, light brown leather. Blind-tooled decorations on
                        both covers, including decorative rectangular frames along the edges, and a
                        centrally-placed rosette (front) and mandorla (back). The author's name, as
                        ‘R. BECHAI’, and the Pococke shelfmark are gold-tooled on the spine.</p>
                     <condition>
                        <p>Some loose quires.</p>
                     </condition>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate when="1190"> 1190 (according to the A.M. dating)</origDate>
                     <origPlace>[Orient (Persia?)]</origPlace>
                  </origin>
                  <provenance>On <locus>f. 142v</locus>, ownership inscriptions by <foreign
                        xml:lang="he">מבורך דאתקרי אלסדיד הכהן בר אברהם</foreign> and <foreign
                        xml:lang="he">מנצור בן מטפר בן מיה</foreign>.</provenance>
                  <acquisition><persName ref="https://viaf.org/en/viaf/41849535">Edward
                        Pococke</persName>'s <date calendar="#Gregorian">(1604-1691)</date>
                     collection of oriental MSS (mostly Armenian, Hebrew and Arabic) was purchased
                     by the Library for £800 in 1692 (see Summary Catalogue, vol. II, p.
                     1008).</acquisition>
               </history>
